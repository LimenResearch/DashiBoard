{
  "filters": [
    {
      "interval": {
        "max": 2012,
        "min": 2011
      },
      "colname": "year",
      "type": "interval"
    },
    {
      "list": ["NW", "SW"],
      "colname": "cbwd",
      "type": "list"
    }
  ],
  "cards": [
    {
      "type": "split",
      "method": { "type": "percentile", "percentile": 0.9 },
      "order_by": ["No"],
      "by": ["cbwd"],
      "output": "_percentile_partition"
    },
    {
      "type": "split",
      "method": { "type": "tiles", "tiles": [1, 1, 2, 1, 1, 2] },
      "order_by": ["No"],
      "by": ["cbwd"],
      "output": "_tiled_partition"
    }
  ]
}
