{
  "nodes": [
    {
      "label": "rescale",
      "card": {
        "type": "rescale",
        "method": "zscore",
        "group_by": { "cols": ["cbwd"] },
        "partition": { "nodes": ["partition"] },
        "inputs": [{ "groups": ["weather"] }, { "cols": ["No"] }]
      }
    },
    {
      "label": "log",
      "card": {
        "type": "rescale",
        "method": "log",
        "inputs": { "cols": ["No"] },
        "suffix": "log"
      }
    },
    {
      "label": "pca",
      "card": {
        "type": "dimensionality_reduction",
        "method": "pca",
        "n_components": 2,
        "inputs": [
          { "nodes": ["log"] },
          { "groups": ["weather"], "through": ["rescale"] }
        ]
      }
    },
    {
      "label": "partition",
      "card": {
        "type": "split",
        "method": "percentile",
        "method_options": { "percentile": 0.9 },
        "order_by": { "cols": ["No"] },
        "output": "partition"
      }
    }
  ],
  "groups": {
    "weather": { "cols": ["PRES", "TEMP"] }
  }
}
