{
  "hasPartition": {
    "type": "glm",
    "formula": {
      "inputs": [1, ["cbwd", "year"], "No"],
      "target": "TEMP"
    },
    "distribution": "normal",
    "partition": "partition",
    "link": "identity"
  },
  "hasWeights": {
    "type": "glm",
    "formula": {
      "inputs": [1, ["cbwd", "year"], "No"],
      "target": "PRES"
    },
    "weights": "Iws",
    "distribution": "gamma"
  },
  "noInputs": {
    "type": "glm",
    "formula": {
      "target": "PRES"
    },
    "weights": "Iws",
    "distribution": "gamma"
  },
  "partition": {
    "type": "split",
    "method": { "type": "percentile", "percentile": 0.9 },
    "order_by": ["No"],
    "output": "partition"
  },
  "isMixed": {
    "type": "mixed_model",
    "formula": {
      "fixed_effect_terms": [1, "year"],
      "random_effect_terms": [1],
      "grouping_factor": "cbwd",
      "target": "TEMP"
    }
  },
  "isMixedHasWeights": {
    "type": "mixed_model",
    "formula": {
      "fixed_effect_terms": [1, "year"],
      "random_effect_terms": [1],
      "grouping_factor": "cbwd",
      "target": "TEMP"
    },
    "weights": "Iws"
  },
  "isMixedNoGrouping": {
    "type": "mixed_model",
    "formula": {
      "fixed_effect_terms": [1, "year"],
      "random_effect_terms": [1],
      "target": "TEMP"
    },
    "weights": "Iws"
  }
}
