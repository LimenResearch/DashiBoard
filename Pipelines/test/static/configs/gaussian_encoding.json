{
  "identity": {
    "type": "gaussian_encoding",
    "input": "month",
    "n_components": 4,
    "lambda": 0.5,
    "suffix": "gaussian",
    "method": { "name": "identity", "max": 12 }
  },
  "dayofweek": {
    "type": "gaussian_encoding",
    "input": "date",
    "n_components": 3,
    "lambda": 0.5,
    "suffix": "gaussian",
    "method": { "name": "dayofweek", "max": 7 }
  },
  "dayofyear": {
    "type": "gaussian_encoding",
    "input": "date",
    "n_components": 12,
    "lambda": 0.5,
    "suffix": "gaussian",
    "method": { "name": "dayofyear", "max": 365 }
  },
  "hour": {
    "type": "gaussian_encoding",
    "input": "time",
    "n_components": 4,
    "lambda": 0.5,
    "suffix": "gaussian",
    "method": { "name": "hourofday", "max": 24 }
  },
  "minute": {
    "type": "gaussian_encoding",
    "input": "time",
    "n_components": 1,
    "lambda": 0.5,
    "suffix": "gaussian",
    "method": { "name": "minuteofhour", "max": 24 }
  },
  "zeroLambda": {
    "type": "gaussian_encoding",
    "input": "time",
    "n_components": 1,
    "lambda": 0,
    "suffix": "gaussian",
    "method": { "name": "minuteofhour", "max": 24 }
  }
}
